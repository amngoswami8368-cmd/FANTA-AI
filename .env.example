# Environment Variables Template
# Copy this file to .env and fill in your values

# === DATABASE ===
MONGODB_URI=mongodb://localhost:27017/fanta-ai
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/fanta-ai

# === AUTHENTICATION ===
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_12345
JWT_EXPIRE=7d

# === AI & EXTERNAL APIs ===
REPLICATE_API_TOKEN=your_replicate_api_token_here
# Get free token at https://replicate.com/account

# === SERVER ===
PORT=5000
NODE_ENV=development
# NODE_ENV=production (for production)

CLIENT_URL=http://localhost:3000
# For production: https://your-frontend-domain.com

# === FILE UPLOAD ===
UPLOAD_DIR=uploads
MAX_FILE_SIZE=52428800
# Max file size in bytes (52428800 = 50MB)

# === SECURITY ===
BCRYPT_ROUNDS=10

# === LOGGING ===
LOG_LEVEL=debug
# Options: error, warn, info, debug, trace
